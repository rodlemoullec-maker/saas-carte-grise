# Imatra — version locale (logiciel installé chez l'agent)
# La majorité de ces variables ont des valeurs par défaut sensées.
# Vous n'avez normalement RIEN à configurer pour un usage local standard.

# ─── APPLICATION ────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_HOST=127.0.0.1
APP_PORT=8001

# Généré automatiquement au premier démarrage si non défini
APP_SECRET_KEY=

# ─── BASE DE DONNÉES — SQLite locale ────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/imatra.db

# ─── STOCKAGE LOCAL DES DOCUMENTS (chiffré) ─────────────────────────────────
STORAGE_PATH=./data/documents

# Généré automatiquement au premier démarrage si non défini
STORAGE_ENCRYPTION_KEY=

# ─── OCR LOCAL ───────────────────────────────────────────────────────────────
OCR_PROVIDER=paddle                 # paddle | tesseract
OCR_CONFIDENCE_THRESHOLD=0.70
OCR_LANGUAGE=fr

# ─── LICENCE (seul appel cloud autorisé) ────────────────────────────────────
LICENSE_SERVER_URL=https://licenses.imatra.fr
LICENSE_CHECK_INTERVAL_HOURS=24
LICENSE_OFFLINE_GRACE_DAYS=30

# ─── MISES À JOUR DES RÈGLES V-XX/C-XX ──────────────────────────────────────
RULES_UPDATE_URL=https://licenses.imatra.fr/rules/latest
RULES_CHECK_INTERVAL_HOURS=24

# ─── LOGS ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_PATH=./data/logs
