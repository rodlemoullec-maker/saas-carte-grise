# ─── APPLICATION ────────────────────────────────────────────────────────────
APP_ENV=development                  # development | staging | production
APP_SECRET_KEY=changeme-32-chars-min
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── BASE DE DONNÉES ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/carte_grise
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── REDIS (cache + queue) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── STOCKAGE DOCUMENTS ──────────────────────────────────────────────────────
STORAGE_BACKEND=local                # local | s3 | gcs
STORAGE_LOCAL_PATH=./data/documents

# S3 (si STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=eu-west-3

# GCS (si STORAGE_BACKEND=gcs)
GCS_BUCKET=
GCS_CREDENTIALS_PATH=

# ─── OCR PROVIDERS ───────────────────────────────────────────────────────────
OCR_PROVIDER=google_docai            # google_docai | azure_form | tesseract
OCR_CONFIDENCE_THRESHOLD=0.70

# Google Document AI
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=eu
GOOGLE_DOCAI_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Azure Form Recognizer
AZURE_FORM_ENDPOINT=
AZURE_FORM_KEY=

# ─── LLM (extraction structurée) ─────────────────────────────────────────────
LLM_PROVIDER=anthropic               # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── APIS EXTERNES ───────────────────────────────────────────────────────────
# INSEE Sirene
INSEE_API_KEY=
INSEE_API_URL=https://api.insee.fr/entreprises/sirene/V3.11

# BAN (Base Adresse Nationale) — pas de clé requise
BAN_API_URL=https://api-adresse.data.gouv.fr

# NHTSA vPIC
NHTSA_API_URL=https://vpic.nhtsa.dot.gov/api

# SIV / ANTS
SIV_API_URL=
SIV_API_KEY=
SIV_HABILITATION_ID=
SIV_ENVIRONMENT=sandbox              # sandbox | production

# ─── NOTIFICATIONS ───────────────────────────────────────────────────────────
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@votredomaine.fr

# SMS (ex: Twilio)
SMS_PROVIDER=twilio                  # twilio | ovh
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── SÉCURITÉ ─────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=500

# ─── WORKERS (Celery) ─────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── MONITORING ───────────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
