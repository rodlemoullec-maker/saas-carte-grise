# === Configuration Carte Grise Auto ===

# Email IMAP (réception des documents de la personne habilitée)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USER=votre_email@gmail.com
IMAP_PASSWORD=votre_mot_de_passe_application

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=carte_grise
DB_USER=carte_grise
DB_PASSWORD=changez_ce_mot_de_passe

# Ollama
OLLAMA_HOST=http://ollama:11434

# Modèle IA — adapter selon la RAM disponible
# 16 GB RAM : qwen2.5:7b
# 32 GB RAM : qwen2.5:14b
# 64 GB RAM : qwen2.5:32b
MODEL_TEXT=qwen2.5:7b
MODEL_VISION=qwen2.5vl:7b
